# P-256 local test Docker (separate from OP-TEE dev environment)
FROM rust:1.83-slim

WORKDIR /test

# Install dependencies
RUN apt-get update && apt-get install -y \
    build-essential \
    python3 \
    python3-pip \
    && rm -rf /var/lib/apt/lists/*

# Install Python cryptography for test vector generation
RUN pip3 install cryptography --break-system-packages

# Copy only what we need for P-256 testing
COPY scripts/test-p256-ta.py /test/

CMD ["python3", "/test/test-p256-ta.py"]
