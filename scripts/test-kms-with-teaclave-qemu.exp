#!/usr/bin/expect -f

# 设置超时时间为10分钟
set timeout 600

# 首先部署我们的TA和host到Teaclave容器
spawn docker exec -it kms-test-std bash -c "
# 创建TA部署目录
mkdir -p /opt/teaclave/images/x86_64-optee-qemuv8-ubuntu-24.04-expand-ta-memory/lib/optee_armtz

# 复制我们的TA文件
cp /workspace/kms/ta/target/aarch64-unknown-optee/release/be2dc9a0-02b4-4b33-ba21-9964dbdf1573.ta \\
   /opt/teaclave/images/x86_64-optee-qemuv8-ubuntu-24.04-expand-ta-memory/lib/optee_armtz/

# 创建host应用部署目录
mkdir -p /opt/teaclave/images/x86_64-optee-qemuv8-ubuntu-24.04-expand-ta-memory/root

# 复制host应用
cp /workspace/kms/host/target/aarch64-unknown-linux-gnu/release/eth_wallet-rs \\
   /opt/teaclave/images/x86_64-optee-qemuv8-ubuntu-24.04-expand-ta-memory/root/

# 设置执行权限
chmod +x /opt/teaclave/images/x86_64-optee-qemuv8-ubuntu-24.04-expand-ta-memory/root/eth_wallet-rs

echo '✅ TA和host文件部署完成'
ls -la /opt/teaclave/images/x86_64-optee-qemuv8-ubuntu-24.04-expand-ta-memory/lib/optee_armtz/be2dc9a0-02b4-4b33-ba21-9964dbdf1573.ta
ls -la /opt/teaclave/images/x86_64-optee-qemuv8-ubuntu-24.04-expand-ta-memory/root/eth_wallet-rs
"

expect {
    "✅ TA和host文件部署完成" {
        puts "✅ 文件部署成功，开始启动QEMU"
    }
    timeout {
        puts "❌ 文件部署超时"
        exit 1
    }
}

# 现在启动加载了我们TA和host的QEMU
spawn docker exec -it kms-test-std bash -c "
export IMG_DIRECTORY='/opt/teaclave/images'
export IMG_NAME='x86_64-optee-qemuv8-ubuntu-24.04-expand-ta-memory'
export QEMU_HOST_SHARE_DIR='/workspace'
/opt/teaclave/bin/start_qemuv8
"

# 期望看到启动过程
expect {
    "NOTICE:  Booting Trusted Firmware" {
        puts "✅ ARM TrustZone Firmware启动成功"
        exp_continue
    }
    "NOTICE:  BL1:" {
        puts "✅ BL1 bootloader启动"
        exp_continue
    }
    "NOTICE:  BL2:" {
        puts "✅ BL2 bootloader启动"
        exp_continue
    }
    "NOTICE:  BL31:" {
        puts "✅ BL31 bootloader启动"
        exp_continue
    }
    "U-Boot" {
        puts "✅ U-Boot启动"
        exp_continue
    }
    "Starting kernel" {
        puts "✅ Linux内核开始启动"
        exp_continue
    }
    "Linux version" {
        puts "✅ Linux内核版本信息显示"
        exp_continue
    }
    "buildroot login:" {
        puts "✅ 系统启动完成，到达登录界面"
        send "root\r"
        expect "#"
        puts "✅ 成功登录系统"

        # 测试系统基本功能
        send "uname -a\r"
        expect "#"

        # 检查我们的TA是否已加载
        send "ls -la /lib/optee_armtz/be2dc9a0-02b4-4b33-ba21-9964dbdf1573.ta\r"
        expect "#"
        puts "✅ 检查TA文件"

        # 测试我们的host应用
        send "ls -la /root/eth_wallet-rs\r"
        expect "#"
        puts "✅ 检查host应用"

        # 尝试运行hello world命令
        send "/root/eth_wallet-rs hello --name 'TEE Test'\r"
        expect {
            "Hello, TEE Test!" {
                puts "🎉 成功！我们的TA和host正常工作！"
                exp_continue
            }
            "#" {
                puts "ℹ️ host应用执行完成"
            }
            timeout {
                puts "⚠️ host应用执行超时，但系统正常"
            }
        }

        # 退出
        send "halt\r"
        expect eof
        exit 0
    }
    timeout {
        puts "❌ 超时：QEMU启动超过10分钟"
        exit 1
    }
    eof {
        puts "❌ QEMU进程意外终止"
        exit 1
    }
}

puts "测试结束"