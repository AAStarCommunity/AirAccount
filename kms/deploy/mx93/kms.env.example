# AirAccount KMS — operator configuration (sample)
# ---------------------------------------------------------------------------
# Copy to /etc/airaccount/kms.env on the host and edit, then restart:
#     sudo install -D -m 600 kms.env.example /etc/airaccount/kms.env
#     sudo systemctl restart kms-api.service
#
# Every value below is OPTIONAL. With no file present the server uses the
# built-in defaults shown after each `=`. None of these require recompiling —
# the binary reads them from the environment at startup.
# ---------------------------------------------------------------------------

# --- WebAuthn relying party -------------------------------------------------
# The relying party (rpId) anchors every passkey to a domain. Fork operators
# running their own instance set this to THEIR domain. Comma-separate to serve
# several domains from one instance (the server picks the rpId whose suffix
# matches the caller's Origin header; falls back to the first entry).
#
# Default: aastar.io
#KMS_RP_ID=example.com
#KMS_RP_ID=kms.example.com,example.com
#
# Local development: browsers treat `localhost` as a secure context, so
# passkeys work over plain http://localhost — no TLS needed. rpId MUST be a
# domain (never an IP), so use `localhost` (not 127.0.0.1) for KMS_RP_ID, while
# KMS_ORIGIN may list both. A ready-made local config lives (gitignored) at
# kms/deploy/local/kms.env:
#   KMS_RP_ID=localhost
#   KMS_ORIGIN=http://localhost:3000,http://127.0.0.1:3000

# Human-readable name shown in the OS passkey prompt.
# Default: AirAccount KMS
#KMS_RP_NAME=Example KMS

# Allowed browser Origins (CORS / WebAuthn origin check), comma-separated.
# Default: https://<first KMS_RP_ID>
#KMS_ORIGIN=https://kms.example.com,https://example.com

# --- API-key authentication -------------------------------------------------
# Protected routes (CreateKey/Sign/SignHash/ListKeys/DeleteKey/… and the
# WebAuthn Begin*/Complete* endpoints) require an `x-api-key` header whenever
# any of these is true:
#   1. the DB has >= 1 key  (provision with: kms-admin api-key generate)
#   2. KMS_API_KEY is set   (single legacy/static key, below)
#   3. KMS_REQUIRE_API_KEY=1 (fail-closed even before any key is provisioned)
#
# Set this to 1 in production so the service never silently runs open.
#KMS_REQUIRE_API_KEY=1

# Optional single static key (in addition to DB-managed keys). Prefer
# `kms-admin api-key generate` for revocable, labelled keys.
#KMS_API_KEY=kms_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Rate limiting ----------------------------------------------------------
# Requests per minute per API key (default: see RateLimiter::from_env).
#KMS_RATE_LIMIT=60
# Requests per minute per agent credential (default: 20).
#KMS_AGENT_RATE_LIMIT=20
# Max distinct keys tracked by the limiter (default: 10000).
#KMS_RATE_LIMIT_MAX_KEYS=10000

# --- Storage ----------------------------------------------------------------
# SQLite path. Default: /data/kms/kms.db if /data/kms exists, else ./kms.db
#KMS_DB_PATH=/data/kms/kms.db

# --- CreateKey gate ---------------------------------------------------------
# Set to 1 to allow CreateKey (kept explicit so a misconfigured instance does
# not mint keys by accident). The shipped unit sets this.
#KMS_ENABLE_CREATEKEY=1
