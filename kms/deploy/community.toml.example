# community.toml — AAStar KMS+DVT 二合一单板部署 · 一个社区一份
# 复制为 community.toml 填好后,被 KMS 和 DVT 共同消费(省一半维护)。
# 用法: deploy-dvt.sh --config community.toml --board <ssh-host>

[community]
name        = "example-community"          # 社区标识
domain      = "kms.example.io"             # 本社区域名 = passkey rpId 锚点(换社区=换域名=换 passkey)
board_ssh   = "root@100.121.187.3"         # 板子 SSH(Tailscale IP 优先,固定不随 DHCP 变)
ssh_key     = "~/.ssh/id_ed25519"

[chain]
eth_rpc_url = "https://eth-sepolia.g.alchemy.com/v2/<YOUR_KEY>"  # 可靠 RPC(公共 sepolia RPC 会 flaky 导致 owner 闸门失败)
entry_point = "0x0000000071727De22E5E9d8BAf0edAc6f37da032"       # ERC-4337 EntryPoint v0.7 canonical

# ── KMS(AirAccount)段 ── 已有部署走 mx93-build/deploy.sh,这里只登记版本/端口供校验
[kms]
version = "0.27.4"
port    = 3000                              # 板上 127.0.0.1:3000(Cloudflare Tunnel 对外)

# ── DVT(aNode / YetAnotherAA-Validator)段 ──
[dvt]
version                   = "1.9.0"         # git tag,deploy 脚本 git archive 该 tag 上板 build
port                      = 8080            # 独立端口,不碰 KMS 的 3000
validator_contract_address = "0xF780Cc3FB161F8df8C076f86E89CE8B685985395"  # ⚠️ 权威值待 repo:dvt 确认(CC 任务)
policy_enabled            = false           # layer-2 策略门;启用需 SP PolicyRegistry 地址
node_name                 = "example-dvt-1"
# node_state.json(独立 BLS12-381 私钥)由 deploy 脚本首次生成,chmod 600,不入库不复用
# 链上注册 registerBLSPublicKey(发现层)本阶段先不做

[runtime]
node_version = "v20.20.2"                   # 官方 glibc linux-arm64(嵌入式板 Docker 常残缺,用 bare-node)
node_dir     = "/opt/node20"
dvt_dir      = "/opt/dvt-build"
