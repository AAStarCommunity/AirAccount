# KMS Passkey 本地测试环境 (独立于主开发环境)
# 用于 P-256 功能测试,不部署到生产

FROM rust:1.83-slim

WORKDIR /workspace

# 安装必要的工具
RUN apt-get update && apt-get install -y \
    build-essential \
    git \
    python3 \
    python3-pip \
    curl \
    && rm -rf /var/lib/apt/lists/*

# 安装 Python 加密库用于生成测试向量
RUN pip3 install cryptography --break-system-packages

# 复制测试工具
COPY kms/passkey-test /workspace/passkey-test

# 构建测试工具 (纯 Rust,无 OP-TEE 依赖)
WORKDIR /workspace/passkey-test
RUN cargo build --release

# 运行测试
CMD ["./target/release/passkey-test"]
